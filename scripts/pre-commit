#!/usr/bin/env bash
set -euo pipefail

STAGED=$(git diff --cached --name-only --diff-filter=ACM -- '*.py')

if [ -z "$STAGED" ]; then
    echo "No Python files staged, skipping checks."
    exit 0
fi

echo "==> ruff check"
# shellcheck disable=SC2086
uv run ruff check $STAGED
echo "    Passed."

echo "==> ruff format --check"
# shellcheck disable=SC2086
uv run ruff format --check $STAGED
echo "    Passed."

echo "==> ty check"
uvx ty check
echo "    Passed."

echo "All pre-commit checks passed."
