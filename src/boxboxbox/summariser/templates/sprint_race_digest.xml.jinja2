<sprint_race_summaries session="{{ session_name }}" circuit="{{ circuit }}" session_type="{{ session_type }}">
{% if final_standings %}
<final_standings>
<!-- duration = total sprint race time (seconds), gap_to_leader = time behind winner (seconds or e.g. "+1 LAP"). -->
{% for r in final_standings %}
  {% if r.position %}
  <result position="{{ r.position }}" driver="{{ r.driver }}"{% if r.duration is not none %} total_time="{{ r.duration | lap_time }}"{% endif %}{% if r.gap_to_leader and r.gap_to_leader != 0 %} gap_to_leader="{{ r.gap_to_leader }}"{% endif %} />
  {% elif r.dnf %}
  <result status="DNF" driver="{{ r.driver }}" />
  {% elif r.dns %}
  <result status="DNS" driver="{{ r.driver }}" />
  {% elif r.dsq %}
  <result status="DSQ" driver="{{ r.driver }}" />
  {% endif %}
{% endfor %}
</final_standings>
{% endif %}
{% for s in summaries %}
<summary window="{{ s.window_start }}-{{ s.window_end }}">
{{ s.text }}
</summary>
{% endfor %}
</sprint_race_summaries>

Produce the post-session audio digest as a Lead/Analyst dialogue following the format in your instructions. Start directly with "Lead: [tag]" — no preamble.
