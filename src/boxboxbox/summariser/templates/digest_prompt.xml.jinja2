<race_summaries session="{{ session_name }}" circuit="{{ circuit }}" session_type="{{ session_type }}">
{% if final_standings %}
<final_standings>
{% for r in final_standings %}
  {% if r.position %}P{{ r.position }}: {{ r.driver }}{% if r.gap_to_leader and r.gap_to_leader != 0 %}{% if r.gap_to_leader is iterable and r.gap_to_leader is not string %} (Q1/Q2/Q3: {{ r.gap_to_leader | join('/') }}){% else %} (+{{ r.gap_to_leader }}){% endif %}{% endif %}
  {% elif r.dnf %}DNF: {{ r.driver }}
  {% elif r.dns %}DNS: {{ r.driver }}
  {% elif r.dsq %}DSQ: {{ r.driver }}
  {% endif %}
{% endfor %}
</final_standings>
{% endif %}
{% for s in summaries %}
<summary window="{{ s.window_start }}-{{ s.window_end }}">
{{ s.text }}
</summary>
{% endfor %}
</race_summaries>

Produce the post-session audio digest as a Lead/Analyst dialogue following the format in your instructions. Start directly with "Lead: [tag]" — no preamble.
