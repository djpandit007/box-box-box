<race_window from="{{ window_start }}" to="{{ window_end }}" session_type="{{ session_type }}"{% if qualifying_phase %} qualifying_phase="{{ qualifying_phase }}"{% endif %}>

<previous_summary>
{{ previous_summary | default("This is the first summary window of the session.") }}
</previous_summary>

{% if no_significant_data %}
<note>No significant events or lap times were recorded during this window. Do not invent or hallucinate events. State briefly that the session is quiet or drivers are on out-laps/installation laps.</note>
{% endif %}

{% if race_control %}
<race_control>
{% for e in race_control %}
  <event time="{{ e.time }}"{% if e.lap %} lap="{{ e.lap }}"{% endif %}{% if e.driver %} driver="{{ e.driver }}"{% endif %}>{{ e.message }}</event>
{% endfor %}
</race_control>
{% endif %}

{% if overtakes %}
<overtakes>
{% for e in overtakes %}
  <event time="{{ e.time }}" position="P{{ e.position }}">{{ e.overtaking_driver }} overtook {{ e.overtaken_driver }} for P{{ e.position }}</event>
{% endfor %}
</overtakes>
{% endif %}

{% if pit_stops %}
<pit_stops>
{% for e in pit_stops %}
  <event time="{{ e.time }}" driver="{{ e.driver }}" lap="{{ e.lap }}">Pit stop: {{ e.stop_duration }}s stationary, {{ e.pit_duration }}s total</event>
{% endfor %}
</pit_stops>
{% endif %}

{% if positions %}
<positions time="{{ positions.time }}">
{% for p in positions.standings %}
  P{{ p.position }}: {{ p.driver }}
{% endfor %}
</positions>
{% endif %}

{% if standings %}
<standings description="Current standings based on fastest lap time so far in this session">
{% for s in standings %}
  <driver position="{{ s.position }}" name="{{ s.driver }}" best_lap="{{ s.best_lap | lap_time }}"{% if s.gap and s.gap > 0 %} gap="+{{ s.gap | lap_time }}"{% endif %} />
{% endfor %}
</standings>
{% endif %}

{% if qualifying_eliminations %}
{% if qualifying_eliminations.q1 %}
<eliminated_after_q1 description="Q1 has just ended. These drivers were eliminated and will not advance to Q2.">
{% for d in qualifying_eliminations.q1 %}
  <driver name="{{ d.driver }}" q1_time="{{ d.q1_time | lap_time }}" />
{% endfor %}
</eliminated_after_q1>
{% endif %}
{% if qualifying_eliminations.q2 %}
<eliminated_after_q2 description="Q2 has just ended. These drivers were eliminated and will not advance to Q3.">
{% for d in qualifying_eliminations.q2 %}
  <driver name="{{ d.driver }}" q2_time="{{ d.q2_time | lap_time }}" />
{% endfor %}
</eliminated_after_q2>
{% endif %}
{% endif %}

{% if qualifying_top10 %}
<qualifying_final_top10 description="Q3 has just ended. These are the top 10 drivers who will form the front of the starting grid.">
{% for d in qualifying_top10 %}
  <driver position="{{ d.position }}" name="{{ d.driver }}" q3_time="{{ d.q3_time | lap_time }}" />
{% endfor %}
</qualifying_final_top10>
{% endif %}

{% if intervals %}
<intervals time="{{ intervals.time }}">
{% for i in intervals.gaps %}
  <gap driver="{{ i.driver }}">gap_to_leader={{ i.gap_to_leader }} interval={{ i.interval }}</gap>
{% endfor %}
</intervals>
{% endif %}

{% if lap_times %}
<lap_times description="Individual laps completed during this window (not necessarily fastest laps)">
{% for e in lap_times %}
  <lap driver="{{ e.driver }}" number="{{ e.lap_number }}" duration="{{ e.duration | lap_time }}" />
{% endfor %}
</lap_times>
{% endif %}

{% if weather %}
<weather time="{{ weather.time }}">
  Air {{ weather.air_temperature }}C, Track {{ weather.track_temperature }}C, Humidity {{ weather.humidity }}%, Wind {{ weather.wind_speed }} km/h dir {{ weather.wind_direction }}deg, Rainfall: {{ "Yes" if weather.rainfall else "No" }}
</weather>
{% endif %}

{% if stints %}
<tyre_stints>
{% for e in stints %}
  <stint driver="{{ e.driver }}" stint="{{ e.stint_number }}" compound="{{ e.compound }}" lap_start="{{ e.lap_start }}" lap_end="{{ e.lap_end }}" tyre_age="{{ e.tyre_age }}" />
{% endfor %}
</tyre_stints>
{% endif %}

</race_window>
