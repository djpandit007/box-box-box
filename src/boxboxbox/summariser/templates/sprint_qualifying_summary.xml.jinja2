<sprint_qualifying_window from="{{ window_start }}" to="{{ window_end }}" session_type="{{ session_type }}"{% if qualifying_phase %} qualifying_phase="{{ qualifying_phase }}"{% endif %}>

<previous_summary>
{{ previous_summary | default("This is the first summary window of the session.") }}
</previous_summary>

{% if session_not_started %}
<note>THE SESSION HAS NOT STARTED. There are no cars on track. Do NOT narrate any on-track action, lap times, or qualifying runs. Focus on race control messages (delays, schedule changes, flag conditions). Only mention weather if there is a significant change (e.g. rain starting, dramatic temperature shift). If there is nothing notable to report, simply state that the session has not yet started.</note>
{% elif session_finished %}
<note>THE SESSION HAS FINISHED. Do NOT narrate any ongoing qualifying action. Only report post-session race control messages (penalties, investigations, grid changes). If there is nothing notable to report, simply state that the session has ended.</note>
{% elif no_significant_data %}
<note>No significant events or lap times were recorded during this window. Do not invent or hallucinate events. State briefly that the session is quiet or drivers are preparing for their runs.</note>
{% endif %}

{% if race_control %}
<race_control>
{% for e in race_control %}
  <event time="{{ e.time }}"{% if e.lap %} lap="{{ e.lap }}"{% endif %}{% if e.driver %} driver="{{ e.driver }}"{% endif %}>{{ e.message }}</event>
{% endfor %}
</race_control>
{% endif %}

{% if standings %}
<standings description="Current standings based on fastest lap time so far in this phase">
{% for s in standings %}
  <driver position="{{ s.position }}" name="{{ s.driver }}" best_lap="{{ s.best_lap | lap_time }}"{% if s.gap and s.gap > 0 %} gap="+{{ s.gap | lap_time }}"{% endif %}{% if s.eliminated %} status="eliminated_{{ s.eliminated }}"{% endif %} />
{% endfor %}
</standings>
{% endif %}

{% if qualifying_eliminations %}
{% if qualifying_eliminations.q1 %}
<eliminated_after_sq1 description="SQ1 has just ended. These drivers were eliminated and will not advance to SQ2.">
{% for d in qualifying_eliminations.q1 %}
  <driver name="{{ d.driver }}" sq1_time="{{ d.q1_time | lap_time }}" />
{% endfor %}
</eliminated_after_sq1>
{% endif %}
{% if qualifying_eliminations.q2 %}
<eliminated_after_sq2 description="SQ2 has just ended. These drivers were eliminated and will not advance to SQ3.">
{% for d in qualifying_eliminations.q2 %}
  <driver name="{{ d.driver }}" sq2_time="{{ d.q2_time | lap_time }}" />
{% endfor %}
</eliminated_after_sq2>
{% endif %}
{% endif %}

{% if qualifying_top10 %}
<sprint_qualifying_final_top10 description="SQ3 has just ended. These are the top 10 drivers who will form the front of the sprint race grid.">
{% for d in qualifying_top10 %}
  <driver position="{{ d.position }}" name="{{ d.driver }}" sq3_time="{{ d.q3_time | lap_time }}" />
{% endfor %}
</sprint_qualifying_final_top10>
{% endif %}

{% if lap_times %}
<lap_times description="Individual laps completed during this window (not necessarily fastest laps)">
{% for e in lap_times %}
  <lap driver="{{ e.driver }}" number="{{ e.lap_number }}" duration="{{ e.duration | lap_time }}" />
{% endfor %}
</lap_times>
{% endif %}

{% if weather %}
<weather time="{{ weather.time }}">
  Air {{ weather.air_temperature }}C, Track {{ weather.track_temperature }}C, Humidity {{ weather.humidity }}%, Wind {{ weather.wind_speed }} km/h dir {{ weather.wind_direction }}deg, Rainfall: {{ "Yes" if weather.rainfall else "No" }}
</weather>
{% endif %}

</sprint_qualifying_window>
